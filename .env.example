# Supabase Configuration (required)
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_anon_key"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"

# Note: The following secrets are configured in Lovable Cloud/Supabase and available to edge functions:
# - SUPABASE_SERVICE_ROLE_KEY (auto-provided)
# - SUPABASE_ANON_KEY (auto-provided)
# - SUPABASE_URL (auto-provided)
# - SUPABASE_DB_URL (auto-provided)
# - TELEGRAM_WEBHOOK_SECRET (configure in Lovable Cloud)
# - SCHEDULED_TASK_SECRET (configure in Lovable Cloud)
#
# Robokassa and Telegram bot credentials are stored in the admin_settings database table,
# not in environment variables.
